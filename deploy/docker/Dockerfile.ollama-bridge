# Build stage
FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /app

COPY go.mod go.sum go.work go.work.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/ollama-bridge ./cmd/ollama-bridge

# Runtime stage
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata wget && \
    addgroup -g 1001 aegisclaw && \
    adduser -D -u 1001 -G aegisclaw aegisclaw

COPY --from=builder /bin/ollama-bridge /usr/local/bin/ollama-bridge
COPY configs/aegisclaw.yaml /etc/aegisclaw/aegisclaw.yaml

USER aegisclaw

EXPOSE 9095

ENTRYPOINT ["ollama-bridge"]
