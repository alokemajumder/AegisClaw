# ═══════════════════════════════════════════════════════════════════
# AegisClaw — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and customize for your deployment.
#
#   cp .env.example .env
#
# Variables with values after the = sign show their defaults.
# Variables marked REQUIRED have no safe default and must be set
# before running in production.
#
# The AEGISCLAW_ prefix is stripped by Viper; dots become underscores.
# Example: AEGISCLAW_DATABASE_HOST maps to config key database.host
# See internal/config/config.go for the full Config struct.
# ═══════════════════════════════════════════════════════════════════


# ─── Security (REQUIRED for production) ───────────────────────────

# JWT signing secret used by api-gateway and orchestrator.
# Generate with: openssl rand -hex 32
AEGISCLAW_AUTH_JWT_SECRET=dev-secret-change-in-production

# JWT access token lifetime (Go duration format).
# Default: 15m
# AEGISCLAW_AUTH_TOKEN_EXPIRY=15m

# JWT refresh token lifetime (Go duration format).
# Default: 168h (7 days)
# AEGISCLAW_AUTH_REFRESH_EXPIRY=168h


# ─── SSO / OIDC (optional) ───────────────────────────────────────

# Enable SSO authentication via OpenID Connect.
# AEGISCLAW_AUTH_SSO_ENABLED=false

# OIDC provider name (e.g. "azure", "okta", "keycloak").
# AEGISCLAW_AUTH_SSO_PROVIDER=

# OIDC issuer URL (e.g. https://login.microsoftonline.com/{tenant}/v2.0).
# AEGISCLAW_AUTH_SSO_ISSUER_URL=

# OIDC client ID registered with the identity provider.
# AEGISCLAW_AUTH_SSO_CLIENT_ID=

# OIDC client secret registered with the identity provider.
# AEGISCLAW_AUTH_SSO_CLIENT_SECRET=


# ─── PostgreSQL ───────────────────────────────────────────────────

# Credentials used by the postgres container AND passed to services.
POSTGRES_USER=aegisclaw
POSTGRES_PASSWORD=aegisclaw
POSTGRES_DB=aegisclaw

# Connection details consumed by AegisClaw Go services.
# In Docker Compose these are set to container hostnames; override
# here only for bare-metal or custom networking.
# AEGISCLAW_DATABASE_HOST=localhost
# AEGISCLAW_DATABASE_PORT=5432
# AEGISCLAW_DATABASE_USER=aegisclaw
# AEGISCLAW_DATABASE_PASSWORD=aegisclaw
# AEGISCLAW_DATABASE_NAME=aegisclaw

# PostgreSQL SSL mode. Use "require" or "verify-full" in production.
# Default: disable
# AEGISCLAW_DATABASE_SSL_MODE=disable

# Maximum number of connections in the pool.
# Default: 25
# AEGISCLAW_DATABASE_MAX_CONNS=25


# ─── NATS + JetStream ────────────────────────────────────────────

# NATS server URL. In Docker Compose the hostname is "nats".
# Default: nats://localhost:4222
# AEGISCLAW_NATS_URL=nats://localhost:4222

# Maximum reconnect attempts before giving up.
# Default: 60
# AEGISCLAW_NATS_MAX_RECONNECTS=60

# Delay between reconnect attempts (Go duration format).
# Default: 2s
# AEGISCLAW_NATS_RECONNECT_WAIT=2s


# ─── MinIO (Evidence Vault) ──────────────────────────────────────

# Root credentials for the MinIO server and S3-compatible access.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Connection details consumed by AegisClaw Go services.
# AEGISCLAW_MINIO_ENDPOINT=localhost:9000
# AEGISCLAW_MINIO_ACCESS_KEY=minioadmin
# AEGISCLAW_MINIO_SECRET_KEY=minioadmin

# S3 bucket name for evidence artifacts.
# Default: aegisclaw-evidence
# AEGISCLAW_MINIO_BUCKET=aegisclaw-evidence

# Use TLS for MinIO connections. Enable in production with a real S3 endpoint.
# Default: false
# AEGISCLAW_MINIO_USE_SSL=false


# ─── Ollama (Local LLM — default backend) ────────────────────────
# Free, open-source, runs on any hardware. Recommended for SMB/SME.
# Model sizing guide:
#   - 1-3B models (llama3.2, phi3): 4GB+ VRAM or CPU-only
#   - 7-8B models (llama3.1, mistral): 8GB+ VRAM (RTX 3060+)
#   - 13B models: 16GB+ VRAM (RTX 4080+)
#   - 70B models (quantized): 24GB+ VRAM (RTX 4090/5090)

# Ollama HTTP endpoint.
# Default: http://localhost:11434
# AEGISCLAW_OLLAMA_URL=http://localhost:11434

# Default model used for LLM reasoning tasks.
# Default: llama3.1
# AEGISCLAW_OLLAMA_DEFAULT_MODEL=llama3.1

# Comma-separated list of models the platform is allowed to use.
# If empty, defaults to: llama3.2, llama3.1, mistral, phi3, gemma2, qwen2.5
# AEGISCLAW_OLLAMA_MODEL_ALLOWLIST=

# Timeout in seconds for a single Ollama inference call.
# Default: 120
# AEGISCLAW_OLLAMA_TIMEOUT_SECONDS=120


# ─── NVIDIA NIM (Optional — high-performance alternative) ───────
# Use NVIDIA NIM for Nemotron or other models via NIM containers.
# Works with: consumer GPUs (RTX 4090/5090), workstation GPUs (RTX PRO),
# DGX Spark/Station, or NVIDIA API Catalog (build.nvidia.com).
#
# Model recommendations by hardware:
#   - RTX 4090/5090 (24GB):     nemotron-nano-8b-v1 (~$1,600-$2,000 GPU)
#   - 2x RTX 4090 or A100:      nemotron-super-49b-v1 (best quality/cost)
#   - DGX / multi-GPU:          nemotron-ultra-253b-v1 (maximum reasoning)
#   - No GPU (cloud API):       Any model via build.nvidia.com (pay-per-token)

# Enable NVIDIA NIM as primary LLM backend.
# Default: false
# AEGISCLAW_NVIDIA_NIM_ENABLED=false

# NIM API endpoint. Cloud: https://integrate.api.nvidia.com/v1
# Self-hosted: http://localhost:8000/v1
# AEGISCLAW_NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1

# NVIDIA API key (required for cloud API, optional for self-hosted).
# Get one at: https://build.nvidia.com/explore/discover
# AEGISCLAW_NVIDIA_NIM_API_KEY=

# Default model for inference.
# Default: nvidia/nemotron-super-49b-v1
# AEGISCLAW_NVIDIA_NIM_DEFAULT_MODEL=nvidia/nemotron-super-49b-v1

# Timeout in seconds for NIM inference.
# Default: 120
# AEGISCLAW_NVIDIA_NIM_TIMEOUT_SECONDS=120


# ─── NeMo Guardrails (Optional — prompt safety) ─────────────────
# NVIDIA NeMo Guardrails NIMs provide content safety, jailbreak detection,
# and topic control for LLM prompts. Runs as separate NIM containers.

# Enable NeMo Guardrails prompt screening.
# Default: false
# AEGISCLAW_NEMO_GUARDRAILS_ENABLED=false

# Content Safety NIM endpoint.
# AEGISCLAW_NEMO_GUARDRAILS_CONTENT_SAFETY_URL=http://localhost:8180/v1

# Jailbreak Detection NIM endpoint.
# AEGISCLAW_NEMO_GUARDRAILS_JAILBREAK_URL=http://localhost:8181/v1

# Topic Control NIM endpoint.
# AEGISCLAW_NEMO_GUARDRAILS_TOPIC_CONTROL_URL=http://localhost:8182/v1


# ─── API Gateway ──────────────────────────────────────────────────

# Port the API gateway listens on (HTTP/REST).
# Default: 8080
# AEGISCLAW_SERVER_API_PORT=8080

# Base port for internal gRPC services (orchestrator=9090, runner=9091, etc.).
# Default: 9090
# AEGISCLAW_SERVER_GRPC_BASE_PORT=9090

# Comma-separated list of allowed CORS origins for the API gateway.
# Default: http://localhost:3000
AEGISCLAW_SERVER_CORS_ORIGINS=http://localhost:3000


# ─── Policy Engine ────────────────────────────────────────────────

# Default playbook pack applied to new engagements.
# Default: default
# AEGISCLAW_POLICY_DEFAULT_PACK=default

# Maximum validation runs allowed per minute (global).
# Default: 100
# AEGISCLAW_POLICY_GLOBAL_RATE_LIMIT=100

# Maximum concurrent validation runs (global).
# Default: 20
# AEGISCLAW_POLICY_GLOBAL_CONCURRENCY_CAP=20


# ─── Observability ────────────────────────────────────────────────

# OpenTelemetry collector / Jaeger OTLP gRPC endpoint.
# Default: http://localhost:4317
# AEGISCLAW_OBSERVABILITY_TRACING_ENDPOINT=http://localhost:4317

# Prometheus metrics scrape port exposed by each Go service.
# Default: 9100
# AEGISCLAW_OBSERVABILITY_METRICS_PORT=9100

# Log level: debug, info, warn, error.
# Default: info
# AEGISCLAW_OBSERVABILITY_LOG_LEVEL=info


# ─── Jaeger ───────────────────────────────────────────────────────

# Enable the OTLP collector inside the Jaeger all-in-one container.
COLLECTOR_OTLP_ENABLED=true


# ─── Grafana ──────────────────────────────────────────────────────

# Admin password for the built-in Grafana instance.
# Change in production.
GF_SECURITY_ADMIN_PASSWORD=admin


# ─── Next.js Frontend ────────────────────────────────────────────

# Server-side rewrite target. Used in next.config.ts to proxy
# /api/* requests to the Go API gateway.
# Default: http://localhost:8080
# API_URL=http://localhost:8080

# Client-side API base URL. Set this to bypass the Next.js proxy
# and call the backend directly (e.g. during development).
# If empty, the frontend uses relative paths through the proxy.
# NEXT_PUBLIC_API_URL=


# ─── CLI (aegiscli) ──────────────────────────────────────────────

# API gateway URL used by the aegiscli command-line tool.
# Default: http://localhost:8080
# AEGISCLAW_API_URL=http://localhost:8080


# ─── Testing ─────────────────────────────────────────────────────

# Full Postgres DSN for integration tests (separate from prod DB).
# Default: postgres://aegisclaw:aegisclaw@localhost:5432/aegisclaw_test?sslmode=disable
# AEGISCLAW_TEST_DATABASE_URL=postgres://aegisclaw:aegisclaw@localhost:5432/aegisclaw_test?sslmode=disable
